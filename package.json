{
  "name": "idel-dream-maker",
  "private": true,
  "version": "2.6.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "predev": "node build.js",
    "prebuild": "node build.js",
    "electron:dev": "node build.js && concurrently \"npm run dev\" \"wait-on http://localhost:1420 && electron .\"",
    "electron:build": "node build.js && vite build && electron-builder"
  },
  "build": {
    "appId": "com.idel.dream-maker",
    "productName": "Idel-DreamMaker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "icons/**/*",
      "pet/**/*",
      "pet-bubble/**/*",
      "pet-context-menu/**/*",
      "pet-selector/**/*",
      "public/**/*",
      "scenarios/**/*.json",
      "package.json"
    ],
    "icon": "icons/icon.png",
    "win": {
      "icon": "icons/icon.ico",
      "target": "portable",
      "signAndEditExecutable": false
    },
    "mac": {
      "icon": "icons/icon.png",
      "target": "dmg",
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "concurrently": "^9",
    "electron": "^34.5.8",
    "electron-builder": "^25",
    "icojs": "^0.23.0",
    "jimp": "^1.6.1",
    "vite": "^6",
    "wait-on": "^8",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "chinese-lunar-calendar": "^1.0.1"
  }
}
