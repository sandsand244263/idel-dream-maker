{
  "name": "idel-dream-maker",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "predev": "node build.js",
    "prebuild": "node build.js",
    "electron:dev": "node build.js && concurrently \"npm run dev\" \"wait-on http://localhost:1420 && electron .\"",
    "electron:build": "node build.js && vite build && electron-builder && node -e \"const f=require('fs'),p=require('path');['win-unpacked','linux-unpacked','mac-unpacked','builder-debug.yml','builder-effective-config.yaml'].forEach(n=>{const d=p.join('release',n);if(f.existsSync(d))f.rmSync(d,{recursive:true,force:true})})\""
  },
  "build": {
    "appId": "com.idel.dream-maker",
    "productName": "Idel-DreamMaker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "icons/**/*",
      "pet/**/*",
      "pet-bubble/**/*",
      "pet-context-menu/**/*",
      "pet-selector/**/*",
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "icon": "icons/icon.png",
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        "portable",
        "zip"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "icon": "icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.entertainment",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "icon": "icons/icon_256.png",
      "target": "tar.gz"
    }
  },
  "devDependencies": {
    "concurrently": "^9",
    "electron": "^34.5.8",
    "electron-builder": "^25",
    "icojs": "^0.23.0",
    "jimp": "^1.6.1",
    "vite": "^6",
    "wait-on": "^8"
  },
  "dependencies": {
    "chinese-lunar-calendar": "^1.0.1",
    "node-global-key-listener": "^0.3.0",
    "yaml": "^2.9.0"
  }
}
