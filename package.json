{
  "name": "idel-dream-maker",
  "private": true,
  "version": "3.7.7",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "predev": "node build.js",
    "prebuild": "node build.js",
    "electron:dev": "node build.js && concurrently \"npm run dev\" \"wait-on http://localhost:1420 && electron .\"",
    "electron:build": "node build.js && vite build && electron-builder --win --x64 && node scripts/inject-icon.cjs"
  },
  "build": {
    "appId": "com.idel.dream-maker",
    "productName": "Idel-DreamMaker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "icons/**/*",
      "pet/**/*",
      "pet-bubble/**/*",
      "pet-context-menu/**/*",
      "pet-selector/**/*",
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "sandsand244263",
      "repo": "idel-dream-maker"
    },
    "win": {
      "icon": "icons/icon_png.ico",
      "target": [
        "portable",
        "zip",
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "Idel-DreamMaker.Setup.${version}.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Idel-DreamMaker"
    },
    "mac": {
      "icon": "icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.entertainment",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "icon": "icons/icon_256.png",
      "target": "tar.gz"
    }
  },
  "devDependencies": {
    "concurrently": "^9",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "icojs": "^0.23.0",
    "jimp": "^1.6.1",
    "rcedit": "^5.0.1",
    "vite": "^6",
    "wait-on": "^8"
  },
  "dependencies": {
    "chinese-lunar-calendar": "^1.0.1",
    "electron-updater": "^6.8.9",
    "uiohook-napi": "^1.5.5",
    "yaml": "^2.9.0"
  }
}
